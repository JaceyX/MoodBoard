{
  "manifest_version": 3,
  "name": "豆包画板 · 多图融合",
  "version": "0.3.0",
  "description": "采集网页图片，标注每张要保留的内容（风格/配色/元素…），用豆包 Seedream 融合成一张原画。",
  "permissions": ["contextMenus", "storage", "unlimitedStorage", "sidePanel"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "打开豆包画板",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
